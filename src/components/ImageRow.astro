---
import type { ImageRowVariant } from './ImageRow.types';

export interface Props {
  variant?: ImageRowVariant;
  className?: string;
  style?: string;
}

const { variant = 'full', className = '', style } = Astro.props;
---

<div
  class:list={['image-row', `image-row--${variant}`, className]}
  style={style}
>
  <slot />
</div>
