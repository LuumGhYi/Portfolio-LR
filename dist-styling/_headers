# Cloudflare Pages headers — same intent as the previous netlify.toml,
# expressed in Cloudflare's _headers format. Pages also reads this on Netlify
# if we ever switch back.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=2592000

# HTML must revalidate to pick up new builds.
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers — cheap defaults for a static portfolio.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
