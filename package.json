{
  "name": "lucas-rageot-portfolio",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:vm": "cross-env PUBLIC_PROFILE=vm astro build --outDir dist-vm",
    "build:styling": "cross-env PUBLIC_PROFILE=styling astro build --outDir dist-styling",
    "build:all": "npm run build:vm && npm run build:styling",
    "deploy:all": "npm run build:all && wrangler pages deploy dist-vm --project-name=portfolio-lucas-rageot && wrangler pages deploy dist-styling --project-name=portfolio-lucas-rageot-styling",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.0",
    "@astrojs/sitemap": "^3.5.1",
    "astro": "^5.16.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "cross-env": "^10.1.0",
    "typescript": "^5.7.3"
  }
}
